{
  "name": "keep-quality-app",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "config-env": "node scripts/generate-config.js",
    "start": "npm run config-env && ng serve",
    "build": "npm run config-env && ng build",
    "watch": "npm run config-env && ng build --watch --configuration development",
    "test": "npm run config-env && ng test",
    "lint": "ng lint"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "pnpm@10.28.1",
  "dependencies": {
    "@angular/animations": "^21.0.6",
    "@angular/cdk": "21.1.3",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@primeuix/themes": "^2.0.2",
    "@supabase/supabase-js": "^2.95.3",
    "angular-auth-oidc-client": "21.0.1",
    "hyperformula": "^3.1.1",
    "monaco-editor": "^0.55.1",
    "ngx-extended-pdf-viewer": "^25.6.4",
    "ngx-monaco-editor-v2": "^20.3.0",
    "primeicons": "^7.0.0",
    "primeng": "^21.0.2",
    "quill": "^2.0.3",
    "rxjs": "~7.8.0",
    "tailwindcss-primeui": "^0.6.1",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.0.4",
    "@angular/cli": "^21.0.4",
    "@angular/compiler-cli": "^21.0.0",
    "@tailwindcss/postcss": "^4.1.18",
    "angular-eslint": "21.1.0",
    "eslint": "^9.39.1",
    "jsdom": "^27.1.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.47.0",
    "vitest": "^4.0.8"
  }
}
